# ============================================================
# SKRIPSIKU — AI Academic Writing Assistant
# Environment Variables Configuration
# ============================================================
# Copy this file to .env (backend) and frontend/.env.local
# Never commit real credentials to version control.

# ────────────────────────────────────────────────────────────
# NVIDIA API Configuration (Hosted Mode)
# ────────────────────────────────────────────────────────────
# Your NVIDIA API key from https://integrate.api.nvidia.com
NVIDIA_API_KEY=your-nvidia-api-key-here

# Base URL for NVIDIA hosted inference
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions

# ────────────────────────────────────────────────────────────
# Model Routing Configuration
# ────────────────────────────────────────────────────────────
# Instant mode — fast, instruction-following, drafting & editing
MODEL_INSTANT=moonshotai/kimi-k2-instruct-0905

# Thinking Standard — stronger reasoning for analysis & critique
MODEL_THINKING_STANDARD=moonshotai/kimi-k2-thinking

# Thinking Extended — deepest reasoning for complex workflows
# (uses kimi-k2-thinking + multi-step orchestration)
MODEL_THINKING_EXTENDED=moonshotai/kimi-k2-thinking

# ────────────────────────────────────────────────────────────
# Deployment Mode
# ────────────────────────────────────────────────────────────
# "hosted"      — single NVIDIA API key, one base URL, model field varies
# "self-hosted" — each model may have its own NIM container URL
NVIDIA_DEPLOYMENT_MODE=hosted

# (Self-hosted only) Per-model NIM container endpoints
# NIM_ENDPOINT_INSTANT=http://localhost:8001/v1/chat/completions
# NIM_ENDPOINT_THINKING=http://localhost:8002/v1/chat/completions

# ────────────────────────────────────────────────────────────
# Application Settings
# ────────────────────────────────────────────────────────────
APP_NAME=Skripsiku
APP_ENV=development
DEBUG=true

# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ────────────────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────────────────
# SQLite (default for local dev)
DATABASE_URL=sqlite:///./skripsiku.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/skripsiku

# ────────────────────────────────────────────────────────────
# Security
# ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256

# Token expiry (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ────────────────────────────────────────────────────────────
# LLM Request Defaults
# ────────────────────────────────────────────────────────────
# Max tokens per LLM call
LLM_MAX_TOKENS_INSTANT=2048
LLM_MAX_TOKENS_THINKING=4096
LLM_MAX_TOKENS_EXTENDED=8192

# Temperature settings
LLM_TEMPERATURE_INSTANT=0.7
LLM_TEMPERATURE_THINKING=0.3
LLM_TEMPERATURE_EXTENDED=0.2

# Retry configuration
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_SECONDS=2

# ────────────────────────────────────────────────────────────
# Frontend (add these to frontend/.env.local)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Skripsiku
NEXT_PUBLIC_APP_VERSION=1.0.0
